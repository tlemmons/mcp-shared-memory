# MCP Shared Memory Server - Environment Configuration
# Copy this to .env and fill in your values:  cp .env.example .env

# MongoDB (required)
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=mcp_orchestrator
MONGO_USER=mcp_orch
MONGO_PASSWORD=changeme

# ChromaDB (required)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Authentication (optional - disabled by default for local use)
# When enabled, memory_start_session requires a valid API key.
# Create keys with the memory_admin tool after enabling.
# MCP_AUTH_ENABLED=true

# Anthropic API key (required only for librarian enrichment service)
# ANTHROPIC_API_KEY=sk-ant-...

# Librarian project roots - JSON map of project name to filesystem path
# Used by the librarian to resolve file paths for code analysis
# LIBRARIAN_PROJECT_ROOTS={"myproject":"/home/user/myproject"}

# External Databases (optional) - use DB_<NAME>_* pattern
# Each database needs at minimum: DB_<NAME>_TYPE and DB_<NAME>_HOST
# Supported types: mssql, mysql
# Default ports: mssql=1433, mysql=3306
#
# MSSQL example:
# DB_MYDB_TYPE=mssql
# DB_MYDB_HOST=myserver.database.windows.net
# DB_MYDB_PORT=1433
# DB_MYDB_NAME=mydb
# DB_MYDB_USER=myuser
# DB_MYDB_PASS=mypassword
# DB_MYDB_READONLY=true
# DB_MYDB_TIMEOUT=30
# DB_MYDB_MAX_ROWS=500
#
# MySQL example:
# DB_OTHERDB_TYPE=mysql
# DB_OTHERDB_HOST=mysql.example.com
# DB_OTHERDB_PORT=3306
# DB_OTHERDB_NAME=otherdb
# DB_OTHERDB_USER=readonly
# DB_OTHERDB_PASS=password
# DB_OTHERDB_READONLY=true
